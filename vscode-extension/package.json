{
  "name": "contextflow-vscode",
  "displayName": "ContextFlow",
  "description": "Local-first Hyper-Context Autonomous Work Engine for VS Code",
  "version": "0.1.2",
  "publisher": "contextflow",
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/trisoft-git/ContextFlow.git"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:contextflow.showSummary",
    "onCommand:contextflow.setGoal",
    "onCommand:contextflow.startSession"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "contextflow.showSummary",
        "title": "ContextFlow: Show Summary"
      },
      {
        "command": "contextflow.setGoal",
        "title": "ContextFlow: Set Goal"
      },
      {
        "command": "contextflow.startSession",
        "title": "ContextFlow: Start Session"
      }
    ],
    "statusBar": [
      {
        "id": "contextflow.status",
        "alignment": "right",
        "priority": 100
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/vscode": "^1.90.0",
    "@types/node": "^20.x",
    "typescript": "^5.x"
  }
}
